# Copy to .env and fill values. Never commit .env
#   cp .env.example .env

# 所有 WebUI 可编辑配置都使用 .env 覆盖 config/*.py 默认值。


# ---- 功能开关 ----
# 启用 Codex OAuth: 注册成功后自动跑 Codex 授权（全新session+接码），落盘 codex-邮箱.json
ENABLE_CODEX_AUTO=

# ---- 注册方式 ----
# 注册驱动: protocol=纯协议；roxy=RoxyBrowser；cloak=CloakBrowser；browser_use=Browser Use Cloud+Playwright
REGISTRATION_DRIVER=

# ---- CloakBrowser ----
# Cloak无头: True=无头运行；False=显示浏览器窗口
CLOAK_HEADLESS=
# Cloak人工行为: 启用 CloakBrowser humanize 鼠标/键盘/滚动行为
CLOAK_HUMANIZE=
# Cloak按出口定位: 按当前出口 IP 自动匹配时区/语言/WebRTC IP；支持显式代理、系统代理/VPN
CLOAK_GEOIP=
# Cloak语言: 留空自动；日本可填 ja-JP，美国 en-US
CLOAK_LOCALE=
# Cloak时区: 留空自动；日本可填 Asia/Tokyo，美国 America/Los_Angeles
CLOAK_TIMEZONE=
# Cloak使用代理: 把本项目传入或代理池抽取的代理传给 CloakBrowser
CLOAK_USE_PROXY=
# Cloak License: Pro license；留空使用免费 binary
CLOAK_LICENSE_KEY=
# Cloak指纹Seed: 留空每次随机；固定值可保持同一指纹
CLOAK_FINGERPRINT_SEED=
# Cloak用户目录: 留空使用临时上下文；填写路径则持久化 cookies/cache
CLOAK_USER_DATA_DIR=
# Cloak超时: 页面和元素等待超时时间，秒
CLOAK_SELENIUM_TIMEOUT=
# 保留Cloak浏览器: 调试时开启，任务结束后不自动关闭
CLOAK_KEEP_BROWSER_OPEN=

# ---- Browser Use ----
# Browser Use API Key: 保存在 .env（BROWSER_USE_API_KEY），不写回 config/*.py
BROWSER_USE_API_KEY=
# 代理国家代码: 两位国家码，如 jp/us/sg；配合 Browser Use 内置 residential proxy
BROWSER_USE_PROXY_COUNTRY_CODE=
# 使用内置代理: True=连接参数带 proxyCountryCode；False=不强制传国家代理参数
BROWSER_USE_USE_PROXY=
# Profile ID: 可选。填写则复用 Browser Use profile 的 cookies/localStorage；批量建议留空
BROWSER_USE_PROFILE_ID=
# CDP 地址: 默认 wss://connect.browser-use.com
BROWSER_USE_CDP_BASE=
# 操作超时(秒): Playwright 默认操作超时
BROWSER_USE_TIMEOUT=
# 快速模式: 减少 Browser Use 额外等待和 humanize 延迟；建议开启，异常排查时可关闭
BROWSER_USE_FAST_MODE=
# 耗时日志: 打印 Browser Use 各阶段耗时：连接、打开页面、邮箱、OTP、手机、callback
BROWSER_USE_LOG_TIMING=
# 保留远端会话: 调试时可不主动 browser.close()；默认 False
BROWSER_USE_KEEP_BROWSER_OPEN=
# 起始 URL: 默认 https://chatgpt.com/auth/login
BROWSER_USE_START_URL=

# ---- RoxyBrowser ----
# Roxy API 地址: 默认 http://127.0.0.1:50000；需在 Roxy 应用 API 配置中开启
ROXY_API_BASE=
# Roxy API Key: 保存在 .env（ROXY_API_TOKEN），不写回 config/*.py
ROXY_API_TOKEN=
# Roxy 环境ID: 指定要打开的 Roxy 浏览器环境/Profile ID；留空则尝试创建临时环境
ROXY_PROFILE_ID=
# Roxy 工作区ID: 创建一号一环境时必填，会作为 workspaceId 提交给 Roxy 创建 Profile 接口
ROXY_WORKSPACE_ID=
# Roxy 项目ID: 从 /browser/workspace 的 project_details.projectId 获取；创建 Profile 时会作为 projectId 提交
ROXY_PROJECT_ID=
# 获取团队接口: 默认 /browser/workspace；点击获取团队/项目时会先试此路径，再自动尝试常见兼容路径
ROXY_WORKSPACE_LIST_PATH=
# 打开接口路径: 默认 /browser/open；如 Roxy 版本不同可在此调整
ROXY_OPEN_PATH=
# 无头启动窗口: 打开 Roxy 环境时向 /browser/open 传 headless；False=显示窗口，True=无头启动
ROXY_OPEN_HEADLESS=
# 关闭接口路径: 默认 /browser/close
ROXY_CLOSE_PATH=
# 保留浏览器: 调试时可开启，任务结束后不自动关闭 Roxy 环境
ROXY_KEEP_BROWSER_OPEN=
# 一号一环境: 每个账号强制创建新 Roxy Profile，用完关闭并删除，禁止复用固定环境
ROXY_ONE_PROFILE_PER_ACCOUNT=
# 结束后删除环境: 一号一环境模式下，任务结束后删除本轮创建的 Roxy Profile
ROXY_DELETE_PROFILE_AFTER_RUN=
# 创建环境使用代理池: 创建 Roxy 环境时从配置页「代理池」随机取一个代理，写入 Roxy proxyInfo
ROXY_CREATE_USE_PROXY_POOL=
# 代理检测通道: 写入 Roxy proxyInfo.checkChannel；留空则不传，默认 IPRust.io
ROXY_PROXY_CHECK_CHANNEL=
# 删除接口路径: 默认 /browser/delete；如 Roxy 版本不同可调整
ROXY_DELETE_PATH=

# ---- CPA / Codex ----
# Codex授权驱动: protocol=原协议授权；roxy=用 RoxyBrowser；cloak=用 CloakBrowser；browser_use=用 Browser Use Cloud；same_as_registration=跟随注册驱动
CODEX_OAUTH_DRIVER=

# ---- RoxyBrowser ----
# Codex回调超时: Roxy Codex OAuth 等待 localhost:1455 callback 的最长秒数
ROXY_CODEX_CALLBACK_TIMEOUT=

# ---- 功能开关 ----
# 启用 2FA(TOTP): 注册完成后自动设置动态口令（会多收一封 OTP 邮件）
ENABLE_2FA=
# 启用 Flow 触发: 注册成功后自动调用内部 Flow 接口（不影响注册结果）
ENABLE_FLOW_TRIGGER=

# ---- 人工节奏 ----
# 启用随机停顿: 在注册、OTP、授权等步骤之间加入随机等待，更接近人工操作节奏
ENABLE_HUMANIZE_DELAY=
# 停顿倍率: 随机停顿整体倍率；1.0=默认，0.5=减半，2.0=加倍
HUMANIZE_DELAY_FACTOR=

# ---- 邮箱 / OTP ----
# 自动取邮箱+收码: True=从邮箱池自动领邮箱并自动收 OTP；False=手动模式：用 REGISTER_EMAIL，OTP 在任务页手填
USE_EMAIL_SERVICE=
# 手动注册邮箱: USE_EMAIL_SERVICE=False 时必填。例如你的 outlook.com 地址；OTP 去网页邮箱看，再回任务页提交
REGISTER_EMAIL=
# 显示名称: 留空则自动生成英文名
REGISTER_NAME=
# OTP 最长等待(秒): 等待验证码邮件的最长秒数，超时判失败
OTP_MAX_WAIT=
# OTP 轮询间隔(秒): 每隔多少秒查一次新邮件
OTP_POLL_INTERVAL=
# 邮箱来源: 可填单个或多个，逗号分隔并按顺序兜底：outlook,generic_api,cloudflare_domain,gptmail
EMAIL_SOURCE=
# Outlook取件模式: auto=远端优先，远端 402/DEPLOYMENT_DISABLED 自动切 Graph 直连；direct=只用 Microsoft Graph 直连；remote=只用远端服务
OUTLOOK_FETCH_MODE=
# Cloudflare 域名: 你的 Cloudflare 域名，如 mydomain.com
EMAIL_DOMAIN=
# QQ 邮箱地址: 接收 Cloudflare 转发邮件的 QQ 邮箱，如 123456@qq.com
QQ_EMAIL=
# QQ 邮箱 IMAP 授权码: 保存在 .env（QQ_IMAP_PASSWORD），不写回 config/*.py
QQ_IMAP_PASSWORD=
# GPTMail API Key: 选择 EMAIL_SOURCE=gptmail 时必填；服务地址固定为 https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=
# MailNest-迈巢 Outlook 临时邮箱的 api key 获取页面 https://mailnest.top/account
MAIL_NEST_API_KEY=

# ---- 浏览器画像 ----
# 地区画像: 应与代理出口地区一致；可选 jp/cn/us/sg。当前本地代理实测为日本东京，推荐 jp
BROWSER_LOCALE_PROFILE=
# 按出口IP自动画像: 开启后每个 BrowserSession 会用当前代理出口 IP 自动选择语言/时区；失败时回退到地区画像
AUTO_BROWSER_LOCALE_FROM_IP=
# IP定位超时(秒): 出口 IP 地理信息接口的单次请求超时；接口失败会自动回退，不影响注册
IP_GEO_TIMEOUT=

# ---- 代理池 ----
# 代理池(每行一个): 每行一个代理 URL，留空行会被忽略；为空则不使用代理
PROXY_POOL=

# ---- CPA / Codex ----
# 授权地址来源: cpa=由 CPA 管理接口生成授权地址；local=旧版本地生成 PKCE 授权地址
CODEX_AUTH_URL_SOURCE=
# CPA 管理地址: 例如 http://localhost:8317/admin/oauth；程序会取 origin 调用 /v0/management/*
CPA_MANAGEMENT_URL=
# 管理密钥: 保存在 .env（CPA_MANAGEMENT_KEY），不写回 config/*.py
CPA_MANAGEMENT_KEY=
# CPA 超时(秒): 请求 CPA 管理接口的超时时间
CPA_REQUEST_TIMEOUT=
# 保存CPA回执: CPA 未返回完整授权文件时，本地仍保存一份回调提交记录
CPA_SAVE_CALLBACK_RECEIPT=

# ---- 接码平台 ----
# 接码通道: grizzly 或 l；l 使用 L_API.md 定义的本地取号服务
SMS_PROVIDER=
# 国家代码: 传给接码平台的 country；GrizzlySMS 常用：美国=187 / 葡萄牙=117 / 智利=151；L 通道按 L 后台配置填写
SMS_COUNTRY=
# 服务代码: 传给接码平台的 service；GrizzlySMS OpenAI=dr；L 通道按 L 后台配置填写
SMS_SERVICE=
# 换号重试次数: 一个号收不到短信/被OpenAI拒时换下一个号，最多重试几次
SMS_MAX_RETRIES=
# 单号等短信(秒): 单个号等待短信到达的最长秒数，超时则换号
SMS_CODE_WAIT=
# API 密钥: 保存在 .env（SMS_API_KEY），不写回 config/*.py
SMS_API_KEY=
# L API 地址: L 取号服务基础地址，例如 http://localhost:8788
L_API_BASE=
# L 授权码: 保存在 .env（L_ADMIN_AUTH_CODE），不写回 config/*.py
L_ADMIN_AUTH_CODE=
# L 号码前缀: L 返回号码不含国家码时填写，例如美国 10 位本地号填 1；留空则不补
L_PHONE_PREFIX=
